<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="TooManyViews">

    <!-- Video Surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/disconnectedBackdrop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/disconnected_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modern Floating Status Bar (Top) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statusBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- FPS Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_fps"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/fpsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dashes"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bitrate Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_bitrate"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/bitrateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dashes"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Resolution Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_resolution"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/resolutionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dashes"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RTT Latency Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_rtt"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/latencyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dashes"
                    android:textColor="#E91E63"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Settings Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settingsButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/display_settings"
            android:src="@drawable/ic_settings"
            app:tint="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <!-- Modern Connection Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settingsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="24dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#F512181C"
        app:cardElevation="18dp"
        app:layout_constraintWidth_max="680dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingTop="32dp"
            android:paddingEnd="40dp"
            android:paddingBottom="28dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@mipmap/ic_launcher"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wordmark"
                android:textColor="#65D992"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.16"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/connectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/waiting_for_mac"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/connectionSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/usb_waiting_description"
                android:textColor="#A8B0B6"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <ProgressBar
                android:id="@+id/connectionProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:indeterminateTint="#65D992" />

            <!-- Mode toggle: USB / Wireless -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/modeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeUSB"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/usb"
                    android:textColor="@color/mode_toggle_text"
                    app:backgroundTint="@color/mode_toggle_bg"
                    app:strokeColor="#444444"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeWireless"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/wireless"
                    android:textColor="@color/mode_toggle_text"
                    app:backgroundTint="@color/mode_toggle_bg"
                    app:strokeColor="#444444"
                    app:strokeWidth="1dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ============= USB MODE CONTENT ============= -->
            <LinearLayout
                android:id="@+id/usbModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Connection Checklist -->
            <LinearLayout
                android:id="@+id/checklistContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/instruction_bg"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_checklist"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Developer Mode Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkDeveloperMode"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textDeveloperMode"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_mode_enabled"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- USB Debugging Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkUsbDebugging"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textUsbDebugging"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/usb_debugging_enabled"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- USB Connected Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:id="@+id/checkUsbConnected"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textUsbConnected"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/usb_cable_connected"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Mac Server Check -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:id="@+id/checkMacServer"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:id="@+id/textMacServer"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/mac_server_running"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Connect Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/try_again"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#07100B"
                app:cornerRadius="18dp"
                app:backgroundTint="#65D992"
                android:layout_marginBottom="14dp" />

            <!-- Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/connection_status_bg"
                android:paddingStart="14dp"
                android:paddingTop="11dp"
                android:paddingEnd="14dp"
                android:paddingBottom="11dp"
                android:layout_marginBottom="12dp">

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_indicator_waiting"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/looking_for_mac"
                    android:textColor="#C4CBD0"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Advanced Settings (collapsed by default) -->
            <LinearLayout
                android:id="@+id/advancedSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#FFFFFF"
                    app:hintTextColor="#AAAAAA"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/hostInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/host"
                        android:text="@string/loopback_host"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#FFFFFF"
                    app:hintTextColor="#AAAAAA">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/portInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/port"
                        android:text="@string/default_port"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Show Advanced link -->
            <TextView
                android:id="@+id/showAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/connection_details"
                android:textColor="#8FB9FF"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="8dp" />

            </LinearLayout>
            <!-- ============= /USB MODE CONTENT ============= -->

            <!-- ============= WIRELESS MODE CONTENT ============= -->
            <LinearLayout
                android:id="@+id/wirelessModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- State: Connecting (auto or after scan) -->
                <LinearLayout
                    android:id="@+id/wirelessConnecting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="#4CAF50"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/connectingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connecting"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/connectingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- State 1: First-time -->
                <LinearLayout
                    android:id="@+id/wirelessFirstTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pair_with_mac"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pair_with_mac_instructions"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="@string/wireless_trusted_network_note"
                        android:textColor="#FBBF24"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessScanButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/scan_qr_code"
                        android:textSize="16sp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4ade80"
                        android:textColor="#000000" />
                </LinearLayout>

                <!-- State 3: Connected -->
                <LinearLayout
                    android:id="@+id/wirelessConnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/connected_status"
                        android:textColor="#4ade80"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/connectedMacName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/mac_default_name"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/connectedMacIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/empty_value"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessDisconnectButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/disconnect"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessForgetButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/forget_this_mac"
                        android:textColor="#fca5a5"
                        app:strokeColor="#7f1d1d" />
                </LinearLayout>

                <!-- State: Paired idle (after explicit Disconnect) -->
                <LinearLayout
                    android:id="@+id/wirelessPairedIdle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/disconnected_status"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/idleMacName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/mac_default_name"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/idleMacIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/empty_value"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessReconnectButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/reconnect"
                        android:textSize="16sp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessIdleForgetButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/forget_this_mac"
                        android:textColor="#fca5a5"
                        app:strokeColor="#7f1d1d" />
                </LinearLayout>

                <!-- State 4: Token mismatch / re-pair -->
                <LinearLayout
                    android:id="@+id/wirelessTokenMismatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/repairTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/could_not_connect"
                        android:textColor="#fca5a5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/repairMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/scan_fresh_qr"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessRescanButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/scan_qr_code"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#4ade80"
                        android:textColor="#000000" />
                </LinearLayout>

                <!-- State 5: Permission denied permanently -->
                <LinearLayout
                    android:id="@+id/wirelessPermDenied"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/instruction_bg"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/camera_permission_required"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/camera_permission_settings_instructions"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wirelessOpenSettingsButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/open_settings"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#007AFF" />
                </LinearLayout>

            </LinearLayout>
            <!-- ============= /WIRELESS MODE CONTENT ============= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:autoLink="web"
                android:gravity="center"
                android:linksClickable="true"
                android:text="@string/fork_credit"
                android:textColor="#7F8A90"
                android:textColorLink="#8FB9FF"
                android:textSize="11sp" />

            <!-- Hidden disconnect button reference (needed by code) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/disconnectButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Hidden log text (needed by code) -->
    <TextView
        android:id="@+id/logText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
